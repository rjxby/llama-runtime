# Platform Selection
# Options: macos-arm64, linux-x64, etc.
PLATFORM=macos-arm64

# Llama.cpp Version
LLAMA_VERSION=b7932

# Dotnet Runtime Identifier
DOTNET_RUNTIME=osx-arm64

# Dependencies Paths
LLAMA_ADAPTER_META_JSON=../../vendor/llama/b7932/macos-arm64/meta.json
MODEL_PATH=models/stories15M-q4_0.gguf

# Server Ports
GRPC_PORT=50051
LLAMA_REST_PORT=4999

# API Keys
ApiKeys__Keys__0=dev-benchmark-key-secure
BENCHMARK_API_KEY=dev-benchmark-key-secure
