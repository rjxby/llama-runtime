{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Llama": {
    "Native": {
      "NativeLibraryPath": "./libllama_adapter.dylib",
      "ContextSize": 4096,
      "BatchSize": 256,
      "GenerationMaxNewTokens": 512
    }
  },
  "Inference": {
    "ChannelCapacity": 100,
    "WorkerCount": 4
  },
  "RateLimiter": {
    "TokenLimit": 2000,
    "TokensPerPeriod": 500,
    "ReplenishmentPeriod": "00:00:01",
    "QueueLimit": 0,
    "RejectionStatusCode": 429,
    "ApiKeyHeaderName": "x-api-key"
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  }
}
